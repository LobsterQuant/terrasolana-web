{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/property/:slug*", "destination": "/property" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/blog/:slug*", "destination": "/blog/:slug*.html" },
    { "source": "/search", "destination": "/search.html" },
    { "source": "/newsletter", "destination": "/newsletter.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/methodology", "destination": "/methodology.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" }
  ]
}
