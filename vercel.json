{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "routes": [
    { "src": "/property/(.*)", "dest": "/property" },
    { "src": "/blog", "dest": "/blog.html" },
    { "src": "/blog/(.*)", "dest": "/blog/$1.html" },
    { "src": "/search", "dest": "/search.html" },
    { "src": "/newsletter", "dest": "/newsletter.html" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/faq", "dest": "/faq.html" },
    { "src": "/methodology", "dest": "/methodology.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/privacy", "dest": "/privacy.html" },
    { "src": "/terms", "dest": "/terms.html" },
    { "src": "/cities/(.*)", "dest": "/cities/$1.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}
